# Required for Web Push in production
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Add a real database for production reminders. Supabase/Neon/Postgres recommended.
DATABASE_URL=
CRON_SECRET=replace-with-long-secret
